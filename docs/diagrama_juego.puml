package "Nucleo del juego" {
    class Juego {
        - ventana : sf::RenderWindow
        - camara : sf::View
        - estaCorriendo : bool
        - mapaSuperficie : unique_ptr<Mundo>
        - mapaExterior : unique_ptr<Mundo>
        - mapaSubsuelo : unique_ptr<Mundo>
        - jugador : unique_ptr<Jugador>
        - animales : vector<Animal*>
        - zombis : vector<Zombie*>
        - aldeanos : vector<Aldeano*>
        - itemsSuelo : vector<ItemSuelo>
        - worldTime : float
        - skyLight : int
        - spawnHostilesHabilitado : bool
        - enSubsuelo : bool
        - posicionEntradaSuperficie : sf::Vector2f
        + Juego()
        + ejecutar()
        - actualizarTiempo(dt: float)
        - puedeDormir() : bool
        - saltarAlAmanecer()
    }

    class Mundo {
        - ancho : int
        - alto : int
        - semillaBase : unsigned int
        - cuadricula : vector<vector<Bloque>>
        - acumuladorCultivos : float
        - filaActualizacionCultivos : int
        + Mundo(ancho: int, alto: int)
        + Mundo(ancho: int, alto: int, semilla: unsigned int)
        + generarMundo(esSubterraneo: bool)
        + actualizarCultivos(dt: float)
        + dibujar(ventana: sf::RenderWindow&)
        + dibujarCapaSuperior(ventana: sf::RenderWindow&, posicionJugador: sf::Vector2f)
        + esBloqueSolido(x: int, y: int) : bool
        + puedeColocarBloque(x: int, y: int) : bool
        + colocarBloque(x: int, y: int, tipo: TipoBloque) : bool
        + alternarPuerta(x: int, y: int) : bool
        + esInteriorTechadoEn(x: int, y: int) : bool
        + ararTierra(x: int, y: int) : bool
        + sembrarCultivo(x: int, y: int, cultivo: TipoBloque) : bool
        + estaCultivoMaduro(x: int, y: int) : bool
        + crearEntradaMina(x: int, y: int) : bool
        + crearZonaEntradaSubterranea(x: int, y: int)
        + talarArbol(x: int, y: int, segundosTrabajo: float, troncosObtenidos: int&, soltoSemilla: bool&) : bool
        + picarEntradaMina(x: int, y: int, segundosTrabajo: float) : bool
        + esMinaAbierta(x: int, y: int) : bool
        + daniarBloque(x: int, y: int, cantidadDanio: float) : bool
        + romperBloque(x: int, y: int)
        + getTipoBloque(x: int, y: int) : TipoBloque
        + getColorMapa(x: int, y: int) : sf::Color
        + guardarEstado(ruta: string) : bool
        + cargarEstado(ruta: string) : bool
    }
}

