@startuml Maincra2D_Arquitectura

left to right direction
skinparam backgroundColor #2D2D2D
skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam class {
    BackgroundColor #454545
    ArrowColor White
    BorderColor #A0A0A0
    FontColor White
    FontName "Courier New"
}
skinparam package {
    BackgroundColor #363636
    BorderColor #888888
    FontColor White
    FontName "Courier New"
}
skinparam note {
    BackgroundColor #3D4F3D
    BorderColor #A0C080
    FontColor White
}

title Maincra 2-D - Arquitectura general conectada

package "Tipos base y datos" {
