package "Subsistemas coordinados por Juego.cpp" as PSubsistemas {
    class SistemaMenu <<subsystem>> {
        + menuInicio()
        + jugar()
        + crearMundo()
        + ayudaOpciones()
        + menuPausa()
        + confirmarSalida()
    }

    class SistemaGuardado <<subsystem>> {
        + escanearMundosGuardados() : vector<MundoGuardado>
        + guardarMetaMundo(mundo: MundoGuardado)
        + leerMetaMundo(ruta) : MundoGuardado
        + guardarMundoActivo()
        + leerEstadoJuego(carpeta) : EstadoJuegoGuardado
        + guardarInventario()
        + guardarEntidadesCercanas()
        + guardarCofres()
    }

    class GeneradorMundo <<subsystem>> {
        + semillaDesdeTexto(texto: string) : unsigned int
        + generarSuperficie()
        + generarSubsuelo()
        + generarAldeas()
        + generarSpawnSeguro()
    }

    class SistemaConstruccionInteraccion <<subsystem>> {
        + seleccionarBloqueMouse()
        + validarRangoJugador()
        + colocarBloque()
        + minarBloque()
        + ararTierra()
        + sembrarCultivo()
        + alternarPuerta()
        + abrirCofre()
        + abrirMesaCrafteo()
        + transicionarCueva()
    }

    class SistemaItemsSuelo <<subsystem>> {
        + crearDrop(item: ItemId, cantidad: int, posicion: sf::Vector2f)
        + actualizarFisicaYFlotacion()
        + atraerAlJugador()
        + recolectarEnInventario()
    }

    class SistemaCofres <<subsystem>> {
        + claveCofre(x: int, y: int) : string
        + generarLootCofreHerreria(slots, semilla, x, y)
        + dibujarUICofre()
        + moverItemCofreInventario()
        + persistirContenido()
    }

    class SistemaTradeo <<subsystem>> {
        + ofertasDeAldeano(profesion: ProfesionAldeano) : vector<OfertaTrade>
        + validarCosto(inventario) : bool
        + consumirCosto()
        + entregarResultado()
        + bloquearOfertaTemporal()
        + dibujarUITradeo()
    }

    class SistemaIluminacion <<subsystem>> {
        + calcularSkyLight(worldTime: float) : int
        + dibujarOscuridadSuperficie()
        + dibujarOscuridadSubsuelo()
        + luzDeAntorchas()
        + bloquearVisionPorPared()
    }

    class SistemaSpawnHostil <<subsystem>> {
        + habilitarConSkyLight()
        + buscarCeldaOscuraLibre()
        + crearZombie()
        + quemarZombiesDeDia()
    }

    class SistemaCombate <<subsystem>> {
        + atacarAnimal()
        + atacarZombie()
        + calcularDanioArma()
        + aplicarKnockback()
        + recibirDanioJugador()
        + generarDropsMuerte()
    }

    class SistemaAudio <<subsystem>> {
        + musicaMenu()
        + clickMenu()
        + popItem()
        + sonidoBloque()
        + ambienteNocheOCueva()
    }

    class SistemaHUD <<subsystem>> {
        + dibujarVida()
        + dibujarHambre()
        + dibujarExperiencia()
        + dibujarOxigeno()
        + dibujarMiniMapa()
        + dibujarSelectorBloque()
    }
}

' Composicion principal
Juego *-- "1 superficie" Mundo : mapaSuperficie
Juego *-- "0..1 exterior" Mundo : mapaExterior
Juego *-- "0..1 subsuelo" Mundo : mapaSubsuelo
Juego *-- "1" Jugador
Juego *-- "0..*" Animal
Juego *-- "0..*" Zombie
Juego *-- "0..*" Aldeano
Juego *-- "0..*" ItemSuelo
Juego *-- "1" InventarioGrid : inventario de sesion
Mundo *-- "ancho x alto" Bloque
InventarioGrid *-- "56" SlotInventario
InventarioGrid *-- "0..*" RecetaCatalogoMesa
RecetaCatalogoMesa *-- "1..*" SlotInventario : ingredientes
SistemaTradeo *-- "1..*" OfertaTrade

' Dependencias de tipos
Bloque --> TipoBloque
Bloque --> TipoBioma
SlotInventario --> ItemId
ItemSuelo --> ItemId
OfertaTrade --> SlotInventario
RecetaCatalogoMesa --> ItemId
Animal --> TipoAnimal
Aldeano --> ProfesionAldeano
ItemRegistry ..> ItemId
ItemRegistry ..> TipoBloque
ItemRegistry ..> TipoHerramienta
SistemaHerramientas ..> TipoBloque
SistemaHerramientas ..> ItemId
SistemaHerramientas ..> TipoHerramienta

' Comunicacion en gameplay
Jugador ..> Mundo : movimiento / colision / agua
Jugador ..> ItemId : accion y arma en mano
Animal ..> Mundo : movimiento, agua y colision
Animal ..> ItemId : tentacion por comida
Animal ..> Jugador : panico por amenaza
Zombie ..> Mundo : navegacion y luz local
Zombie ..> Jugador : persecucion, ataque y knockback
Aldeano ..> Mundo : puertas, casas y refugio
Aldeano ..> ProfesionAldeano
InventarioGrid ..> ItemRegistry : stacks, nombres y colocables
InventarioGrid ..> ItemId : hotbar, cursor y segunda mano
InventarioGrid ..> TipoBloque : item colocable a bloque

' Orquestacion de subsistemas
Juego ..> SistemaMenu : estados de menu
Juego ..> SistemaGuardado : crear, cargar, guardar mundo
Juego ..> GeneradorMundo : semilla, aldeas, cuevas, spawn
Juego ..> SistemaConstruccionInteraccion : mouse, rango e interaccion
Juego ..> SistemaItemsSuelo : drops, fisica y recoleccion
Juego ..> SistemaCofres : cofre activo y loot
Juego ..> SistemaTradeo : aldeano activo y ofertas
Juego ..> SistemaIluminacion : worldTime, skyLight y antorchas
Juego ..> SistemaSpawnHostil : zombies por oscuridad
Juego ..> SistemaCombate : dano, drops y empuje
Juego ..> SistemaAudio : musica y efectos
Juego ..> SistemaHUD : vida, hambre, selector y minimapa

' Flujo entre subsistemas
SistemaMenu ..> SistemaGuardado : lista mundos / crear mundo
SistemaMenu ..> GeneradorMundo : nueva partida con semilla
SistemaGuardado ..> MundoGuardado
SistemaGuardado ..> EstadoJuegoGuardado
SistemaGuardado ..> Mundo : blocks.bin / cave_blocks.bin
SistemaGuardado ..> InventarioGrid : inventory.txt
SistemaGuardado ..> Jugador : player.txt
SistemaGuardado ..> Zombie : entities.txt
SistemaGuardado ..> Aldeano : entities.txt
SistemaGuardado ..> SistemaCofres : chests.txt

GeneradorMundo ..> Mundo : generarMundo()
GeneradorMundo ..> TipoBioma
GeneradorMundo ..> TipoBloque
GeneradorMundo ..> Aldeano : poblacion inicial de aldeas

SistemaConstruccionInteraccion ..> Jugador : posicion y rango
SistemaConstruccionInteraccion ..> Mundo : colocar, minar, arar, sembrar
SistemaConstruccionInteraccion ..> InventarioGrid : item en hotbar / consumir
SistemaConstruccionInteraccion ..> SistemaHerramientas : tiempo y drop valido
SistemaConstruccionInteraccion ..> SistemaItemsSuelo : drops por bloque
SistemaConstruccionInteraccion *-- "0..*" ParticulaBloque : grietas y particulas
SistemaConstruccionInteraccion ..> SistemaCofres : abrir cofre
SistemaConstruccionInteraccion ..> SistemaAudio : feedback

SistemaItemsSuelo ..> ItemSuelo
SistemaItemsSuelo ..> Jugador : atraccion al pecho
SistemaItemsSuelo ..> InventarioGrid : agregarItem()
SistemaItemsSuelo ..> SistemaAudio : pop de recoleccion

SistemaCofres ..> Mundo : bloque Cofre
SistemaCofres ..> SlotInventario : contenido
SistemaCofres ..> InventarioGrid : transferir items
SistemaCofres ..> SistemaGuardado : persistencia

SistemaTradeo ..> Aldeano : profesion y bloqueo
SistemaTradeo ..> InventarioGrid : validar, consumir y entregar
SistemaTradeo ..> OfertaTrade
SistemaTradeo ..> SistemaAudio : click de trade

SistemaIluminacion ..> Mundo : antorchas y bloqueos de luz
SistemaIluminacion ..> Jugador : luz por item en mano
SistemaIluminacion ..> InventarioGrid : antorcha / mapa en segunda mano
SistemaIluminacion ..> SistemaSpawnHostil : umbral de oscuridad
SistemaIluminacion ..> SistemaHUD : oscurecer pantalla

SistemaSpawnHostil ..> Mundo : celda libre y luz baja
SistemaSpawnHostil ..> Jugador : distancia segura
SistemaSpawnHostil ..> Zombie : crear / actualizar ciclo
SistemaSpawnHostil ..> SistemaIluminacion : skyLight

SistemaCombate ..> Jugador : vida, invulnerabilidad y experiencia
SistemaCombate ..> Animal : dano, panico y muerte
SistemaCombate ..> Zombie : dano y muerte
SistemaCombate ..> InventarioGrid : arma en hotbar
SistemaCombate ..> SistemaItemsSuelo : drops
SistemaCombate ..> SistemaAudio : golpe / muerte

SistemaHUD ..> Jugador : vida, hambre, XP, oxigeno
SistemaHUD ..> InventarioGrid : hotbar, segunda mano y minimapa
SistemaHUD ..> Mundo : colores del mapa y selector
SistemaHUD ..> SistemaIluminacion : brillo final

SistemaAudio ..> SistemaMenu : click y musica
SistemaAudio ..> SistemaConstruccionInteraccion : romper / colocar
SistemaAudio ..> SistemaItemsSuelo : pop
SistemaAudio ..> SistemaCombate : dano y ataque

note right of Juego
Juego es el orquestador principal:
- decide si se actualiza gameplay o UI
- alterna superficie/subsuelo
- actualiza tiempo, luz y spawns
- comunica mundo, entidades, inventario y guardado
end note

note bottom of PSubsistemas
Estos subsistemas son responsabilidades ya coordinadas desde Juego.cpp.
Se muestran separados para que el diagrama sea escalable y no deje
funciones importantes escondidas o sin conexion.
end note

@enduml
